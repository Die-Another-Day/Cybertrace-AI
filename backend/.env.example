# ── Application ──────────────────────────────────────────────
APP_NAME=CyberTrace AI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cybertrace:password@localhost:5432/cybertrace_db
SYNC_DATABASE_URL=postgresql://cybertrace:password@localhost:5432/cybertrace_db

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Encryption ────────────────────────────────────────────────
AES_ENCRYPTION_KEY=your-32-byte-aes-key-change-in-production

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,mp3,mp4,wav,ogg,doc,docx,txt

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
